rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, role, photoURL, phoneNumber, isVerified, idPhotoURL, location, walletBalance, createdAt
    //
    // Collection: orders
    // Fields: id, customerId, riderId, sellerId, status, items, customRequest, deliveryAddress, deliveryLocation, totalPrice, deliveryFee, adminFee, paymentMethod, paymentStatus, receiptURL, proofOfPurchaseURL, proofOfDeliveryURL, customerApprovedPrices, createdAt, updatedAt
    //
    // Collection: products
    // Fields: id, sellerId, name, description, price, imageURL, category, isAvailable
    //
    // Collection: transactions
    // Fields: id, userId, orderId, amount, type, status, createdAt
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "jeffzhub@gmail.com" && request.auth.token.email_verified == true));
    }

    function isRider() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'rider';
    }

    function isSeller() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'seller';
    }

    function isCustomer() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'customer';
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.uid is string &&
             data.email is string &&
             data.role in ['customer', 'rider', 'seller', 'admin'] &&
             (!('walletBalance' in data) || data.walletBalance is number);
    }

    function isValidOrder(data) {
      return data.customerId is string &&
             data.status in ['pending', 'accepted', 'purchasing', 'delivering', 'completed', 'cancelled'] &&
             (!('totalPrice' in data) || data.totalPrice is number);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Users Collection
    match /users/{userId} {
      // Users can read their own profile. Admins can read all.
      // Public profiles are NOT allowed because users collection contains PII (email).
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own profile with 'customer' role by default.
      // Only admins can create other roles or verify users.
      allow create: if isAuthenticated() && 
                    isValidUser(request.resource.data) && 
                    (isOwner(userId) && request.resource.data.role == 'customer' || isAdmin());
      
      // Users can update their own profile but NOT their role or verification status.
      allow update: if isAuthenticated() && 
                    isValidUser(request.resource.data) && 
                    (isOwner(userId) && 
                     request.resource.data.role == resource.data.role && 
                     request.resource.data.isVerified == resource.data.isVerified || 
                     isAdmin());
    }

    // Orders Collection
    match /orders/{orderId} {
      // Customers can read their own orders. Riders can read orders they've accepted or pending orders.
      allow read: if isAuthenticated() && 
                  (resource.data.customerId == request.auth.uid || 
                   resource.data.riderId == request.auth.uid || 
                   resource.data.status == 'pending' || 
                   isAdmin());
      
      // Customers can create orders.
      allow create: if isCustomer() && 
                    isValidOrder(request.resource.data) && 
                    request.resource.data.customerId == request.auth.uid;
      
      // Atomic Job Locking & Status Updates
      allow update: if isAuthenticated() && 
                    isValidOrder(request.resource.data) && 
                    (
                      // Rider accepting a pending order (Job Locking)
                      (resource.data.status == 'pending' && 
                       request.resource.data.status == 'accepted' && 
                       request.resource.data.riderId == request.auth.uid && 
                       areImmutableFieldsUnchanged(['customerId', 'items', 'createdAt'])) ||
                      
                      // Rider updating status or marking admin fee as paid
                      (resource.data.riderId == request.auth.uid && 
                       request.resource.data.riderId == resource.data.riderId &&
                       (request.resource.data.adminFeeStatus == 'paid' || request.resource.data.adminFeeStatus == resource.data.adminFeeStatus)) ||
                      
                      // Customer approving prices or cancelling
                      (resource.data.customerId == request.auth.uid && 
                       request.resource.data.customerId == resource.data.customerId) ||
                      
                      // Admin confirming admin fee payment
                      (isAdmin() && request.resource.data.adminFeeStatus == 'confirmed') ||
                      
                      isAdmin()
                    );
    }

    // Messages Collection
    match /messages/{messageId} {
      allow read: if isAuthenticated() && 
                  (get(/databases/$(database)/documents/orders/$(resource.data.orderId)).data.customerId == request.auth.uid ||
                   get(/databases/$(database)/documents/orders/$(resource.data.orderId)).data.riderId == request.auth.uid ||
                   isAdmin());
      
      allow create: if isAuthenticated() && 
                    (get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.customerId == request.auth.uid ||
                     get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.riderId == request.auth.uid) &&
                    request.resource.data.senderId == request.auth.uid;
    }

    // Products Collection
    match /products/{productId} {
      allow read: if true; // Products are publicly readable
      allow create: if isSeller() && request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if isSeller() && resource.data.sellerId == request.auth.uid || isAdmin();
    }

    // Transactions Collection
    match /transactions/{transactionId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAdmin(); // Only system/admin can create transactions
    }
  }
}
